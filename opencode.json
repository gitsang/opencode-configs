{
  "$schema": "https://opencode.ai/config.json",
  "logLevel": "DEBUG",
  "plugin": [
    "opencode-webhook-notify@git+https://github.com/gitsang/opencode-webhook-notify.git",
    "./plugins/opencode-context-cache.mjs",
    "oh-my-openagent"
  ],
  "default_agent": "sisyphus",
  "formatter": {
    "shfmt": {
      "disabled": true
    }
  },
  "provider": {
    "saigw-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Saigw (Anthropic)",
      "options": {
        "baseURL": "https://aigw.cn.c8g.top/anthropic/v1"
      },
      "models": {
        "claude-sonnet-5": {
          "name": "Claude Sonnet 5",
          "limit": {
            "context": 1048576,
            "output": 131072
          }
        }
      }
    },
    "saigw-openai": {
      "npm": "@ai-sdk/openai",
      "name": "Saigw (OpenAI)",
      "options": {
        "baseURL": "https://aigw.cn.c8g.top/v1",
        "setCacheKey": true
      },
      "models": {
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini",
          "options": {
            "store": false,
            "serviceTier": "priority",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          },
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "gpt-5.6-sol": {
          "name": "GPT 5.6 Sol",
          "options": {
            "store": false,
            "serviceTier": "priority",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "limit": {
            "context": 361472,
            "output": 128000
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            },
            "max": {
              "reasoningEffort": "max"
            }
          }
        },
        "gpt-5.6-terra": {
          "name": "GPT 5.6 Terra",
          "options": {
            "store": false,
            "serviceTier": "priority",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "limit": {
            "context": 361472,
            "output": 128000
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            },
            "max": {
              "reasoningEffort": "max"
            }
          }
        },
        "gpt-5.6-luna": {
          "name": "GPT 5.6 Luna",
          "options": {
            "store": false,
            "serviceTier": "priority",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "limit": {
            "context": 361472,
            "output": 128000
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            },
            "max": {
              "reasoningEffort": "max"
            }
          }
        }
      }
    },
    "saigw-compatible": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Saigw (Compatible)",
      "options": {
        "baseURL": "https://aigw.cn.c8g.top/v1"
      },
      "models": {
        "glm-5.2": {
          "name": "GLM 5.2",
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 1000000,
            "output": 131072
          }
        },
        "kimi-k3": {
          "name": "Kimi K3",
